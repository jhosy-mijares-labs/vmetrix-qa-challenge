{
  "name": "vmetrix-qa-challenge",
  "version": "1.0.0",
  "description": "QA Automation Challenge | Playwright + TypeScript + Allure | UI & API Testing",
  "main": "index.js",
  "scripts": {
    "test:ui": "npx playwright test src/tests/ui/ --project='UI Tests - Chrome'",
    "test:api": "npx playwright test src/tests/api/ --project='API Tests'",
    "test:all": "npx playwright test",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhosy-mijares-labs/vmetrix-qa-challenge.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jhosy-mijares-labs/vmetrix-qa-challenge/issues"
  },
  "homepage": "https://github.com/jhosy-mijares-labs/vmetrix-qa-challenge#readme",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "allure-js-commons": "^3.10.0",
    "allure-playwright": "^3.10.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}